{
  "$schema": "https://json.schemastore.org/package.json",
  "version": "1.17.8",
  "name": "@talon-ai/core",
  "type": "module",
  "license": "MIT",
  "private": true,
  "scripts": {
    "db": "bun drizzle-kit",
    "migration": "bun run script/migration.ts",
    "fix-node-pty": "bun run script/fix-node-pty.ts",
    "test": "bun test --only-failures",
    "typecheck": "tsgo --noEmit"
  },
  "bin": {
    "talon": "./bin/talon"
  },
  "exports": {
    "./public": "./src/public/index.ts",
    "./session/runner": "./src/session/runner/index.ts",
    "./session/intent": "./src/session/intent.ts",
    "./system-context": "./src/system-context/index.ts",
    "./repomap": "./src/repomap/index.ts",
    "./hashline": "./src/hashline.ts",
    "./config/context": "./src/config/context.ts",
    "./tool/comment-checker": "./src/tool/comment-checker.ts",
    "./loop": "./src/loop/index.ts",
    "./plugin/skill-mcp": "./src/plugin/skill-mcp.ts",
    "./*": "./src/*.ts"
  },
  "imports": {
    "#sqlite": {
      "bun": "./src/database/sqlite.bun.ts",
      "node": "./src/database/sqlite.node.ts",
      "default": "./src/database/sqlite.bun.ts"
    },
    "#pty": {
      "bun": "./src/pty/pty.bun.ts",
      "node": "./src/pty/pty.node.ts",
      "default": "./src/pty/pty.bun.ts"
    },
    "#fff": {
      "bun": "./src/filesystem/fff.bun.ts",
      "node": "./src/filesystem/fff.node.ts",
      "default": "./src/filesystem/fff.bun.ts"
    }
  },
  "devDependencies": {
    "@tsconfig/bun": "catalog:",
