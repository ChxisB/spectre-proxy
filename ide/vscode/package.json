{
  "name": "spectre-proxy",
  "displayName": "Spectre Proxy",
  "description": "Spectre Proxy command center — proxy status, dashboard launcher, and agent controls",
  "version": "0.1.0",
  "publisher": "spectre-proxy",
  "license": "MIT",
  "engines": { "vscode": "^1.96.0" },
  "categories": ["Other"],
  "activationEvents": ["onStartupFinished", "onView:spectre-proxy.chatView"],
  "main": "./dist/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "spectre-proxy.dashboard",
        "title": "Spectre Proxy: Open Dashboard",
        "icon": "$(link-external)"
      },
      {
        "command": "spectre-proxy.startProxy",
        "title": "Spectre Proxy: Start Proxy"
      },
      {
        "command": "spectre-proxy.stopProxy",
        "title": "Spectre Proxy: Stop Proxy"
      },
      {
        "command": "spectre-proxy.restartProxy",
        "title": "Spectre Proxy: Restart Proxy"
      },
      {
        "command": "spectre-proxy.openSettings",
        "title": "Spectre Proxy: Open Settings"
      },
      {
        "command": "spectre-proxy.terminal",
        "title": "Spectre Proxy: Open Terminal"
      }
    ],
    "viewsContainers": {
      "activitybar": [
        {
          "id": "spectreSidebar",
          "title": "Spectre Proxy",
          "icon": "resources/icon.svg"
        }
      ]
    },
    "views": {
      "spectreSidebar": [
        {
          "type": "webview",
          "id": "spectre-proxy.chatView",
          "name": "Chat",
          "icon": "resources/icon.svg"
        }
      ]
    },
    "menus": {
      "view/title": [
        {
          "command": "spectre-proxy.startProxy",
          "when": "view == spectre-proxy.chatView",
          "group": "navigation"
        },
        {
          "command": "spectre-proxy.stopProxy",
          "when": "view == spectre-proxy.chatView",
          "group": "navigation"
        },
        {
          "command": "spectre-proxy.restartProxy",
          "when": "view == spectre-proxy.chatView",
          "group": "navigation"
        }
      ]
    },
    "configuration": {
      "title": "Spectre Proxy",
      "properties": {
        "spectre-proxy.proxyPort": {
          "type": "number",
          "default": 8082,
          "description": "Port for the Spectre Proxy proxy"
        },
        "spectre-proxy.dashboardUrl": {
          "type": "string",
          "default": "http://localhost:3000",
          "description": "URL of the Spectre Proxy dashboard"
        },
        "spectre-proxy.proxyBinPath": {
          "type": "string",
          "default": "",
          "description": "Path to the spectre-server binary (auto-detected if empty)"
        },
        "spectre-proxy.autoStart": {
          "type": "boolean",
          "default": false,
          "description": "Auto-start proxy when VS Code launches"
        },
        "spectre-proxy.proxyApiKey": {
          "type": "string",
          "default": "spectre-proxy",
          "description": "x-api-key sent to the proxy"
        }
      }
    }
  },
  "scripts": {
    "build": "esbuild src/extension.ts --bundle --outfile=dist/extension.js --external:vscode --format=cjs --platform=node",
    "watch": "esbuild src/extension.ts --bundle --outfile=dist/extension.js --external:vscode --format=cjs --platform=node --watch",
    "lint": "eslint src/"
  },
  "devDependencies": {
    "@types/vscode": "^1.96.0",
    "esbuild": "^0.25.0",
    "typescript": "^5.7.0"
  }
}
